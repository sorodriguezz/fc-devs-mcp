{
  "name": "fc-devs-mcp",
  "version": "1.0.0",
  "description": "A Model Context Protocol server for FC Devs — IRIS InterSystems & Azure DevOps integration.",
  "homepage": "https://github.com/sorodriguezz/fc-devs-mcp#readme",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "fc-mcp": "dist/index.js"
  },
  "bugs": {
    "url": "https://github.com/sorodriguezz/fc-devs-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sorodriguezz/fc-devs-mcp.git"
  },
  "license": "MIT",
  "author": "sorodriguezz",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --watch dist/index.js",
    "inspect": "tsc && npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@intersystems/intersystems-iris-native": "^2.0.3",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "dotenv": "^17.3.1",
    "env-var": "^7.5.0",
    "mssql": "^11.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/mssql": "^9.1.5",
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "README.es.md",
    ".env.example"
  ],
  "keywords": [
    "mcp",
    "iris",
    "intersystems",
    "azure",
    "devops",
    "model-context-protocol"
  ]
}
