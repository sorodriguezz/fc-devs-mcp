{
  "servers": {

    // ── Modo local: apunta al dist compilado del repositorio clonado ──────────
    "fc-mcp-local": {
      "type": "stdio",
      "command": "node",
      "args": ["${workspaceFolder}/dist/index.js"],
      "env": {
        "MCP_SERVER_NAME": "FC-MCP-Local",
        "IRIS_ENABLED": "true",
        "IRIS_HOSTNAME": "10.0.0.42",
        "IRIS_PORT": "1972",
        "IRIS_NAMESPACE": "APPNS",
        "IRIS_USERNAME": "admin",
        "IRIS_PASSWORD": "s3cr3tIris!",
        "MSSQL_ENABLED": "false",
        "ADO_ENABLED": "false"
      }
    },

    // ── Modo local: SQL Server con Entra ID (Active Directory - Password) ──────
    // Igual que DBeaver: solo usuario (correo Entra ID) + contraseña.
    // El client ID usa el client público de Azure SQL por defecto y el tenant
    // se deriva del dominio del correo, así que NO hace falta tenant/client ID.
    "fc-mcp-mssql-entra": {
      "type": "stdio",
      "command": "node",
      "args": ["${workspaceFolder}/dist/index.js"],
      "env": {
        "MCP_SERVER_NAME": "FC-MCP-MSSQL-Entra",
        "IRIS_ENABLED": "false",
        "ADO_ENABLED": "false",
        "MSSQL_ENABLED": "true",
        "MSSQL_AUTH": "azure-ad-password",
        "MSSQL_HOSTNAME": "mi-servidor.database.windows.net",
        "MSSQL_PORT": "1433",
        "MSSQL_DATABASE": "mi_base_datos",
        "MSSQL_USERNAME": "usuario@empresa.cl",
        "MSSQL_PASSWORD": "tu-contrasena-entra-id",
        "MSSQL_ENCRYPT": "true"
      }
    },

    // ── Modo local con dos instancias (IRIS + ADO) ────────────────────────────
    "fc-mcp-local-full": {
      "type": "stdio",
      "command": "node",
      "args": ["${workspaceFolder}/dist/index.js"],
      "env": {
        "MCP_SERVER_NAME": "FC-MCP-Local-Full",
        "IRIS_ENABLED": "true",
        "IRIS_HOSTNAME": "10.0.0.42",
        "IRIS_PORT": "1972",
        "IRIS_NAMESPACE": "APPNS",
        "IRIS_USERNAME": "admin",
        "IRIS_PASSWORD": "s3cr3tIris!",
        "MSSQL_ENABLED": "true",
        "MSSQL_HOSTNAME": "10.0.1.55",
        "MSSQL_PORT": "1433",
        "MSSQL_DATABASE": "inventory_db",
        "MSSQL_USERNAME": "app_user",
        "MSSQL_PASSWORD": "Sup3rS3cur3!",
        "MSSQL_ENCRYPT": "false",
        "MSSQL_TRUST_SERVER_CERT": "true",
        "ADO_ENABLED": "true",
        "AZURE_DEVOPS_ORG_URL": "https://dev.azure.com/contoso-devs",
        "AZURE_DEVOPS_PAT": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
      }
    },

    // ── Modo npmjs: siempre la última versión publicada ───────────────────────
    // npx.cmd + "--yes --prefer-online" obliga a npx a consultar npm en cada
    // arranque, ignorando la caché local, para usar siempre la última versión.
    // (En macOS/Linux usa "npx" en lugar de "npx.cmd").
    "fc-mcp-npm-latest": {
      "type": "stdio",
      "command": "npx.cmd",
      "args": ["--yes", "--prefer-online", "fc-devs-mcp"],
      "env": {
        "MCP_SERVER_NAME": "FC-MCP-NPM-Latest",
        "IRIS_ENABLED": "true",
        "IRIS_HOSTNAME": "10.0.0.42",
        "IRIS_PORT": "1972",
        "IRIS_NAMESPACE": "APPNS",
        "IRIS_USERNAME": "admin",
        "IRIS_PASSWORD": "s3cr3tIris!",
        "MSSQL_ENABLED": "false",
        "ADO_ENABLED": "false"
      }
    },

    // ── Modo npmjs: SQL Server con Entra ID, siempre la última versión ─────────
    // Solo usuario + contraseña (igual que DBeaver). Requiere haber publicado
    // la versión con soporte azure-ad-password.
    "fc-mcp-mssql-entra-npm": {
      "type": "stdio",
      "command": "npx.cmd",
      "args": ["--yes", "--prefer-online", "fc-devs-mcp"],
      "env": {
        "MCP_SERVER_NAME": "FC-MCP-MSSQL-Entra-NPM",
        "IRIS_ENABLED": "false",
        "ADO_ENABLED": "false",
        "MSSQL_ENABLED": "true",
        "MSSQL_AUTH": "azure-ad-password",
        "MSSQL_HOSTNAME": "mi-servidor.database.windows.net",
        "MSSQL_PORT": "1433",
        "MSSQL_DATABASE": "mi_base_datos",
        "MSSQL_USERNAME": "usuario@empresa.cl",
        "MSSQL_PASSWORD": "tu-contrasena-entra-id",
        "MSSQL_ENCRYPT": "true"
      }
    }

  }
}
