# ── Servidor MCP ──────────────────────────────────────────────────────────────
MCP_SERVER_NAME=FC-MCP-Server
MCP_SERVER_VERSION=1.0.0

# ── InterSystems IRIS ──────────────────────────────────────────────────────────
# Poner en false para deshabilitar esta integración
IRIS_ENABLED=true
IRIS_HOSTNAME=localhost
IRIS_PORT=1972
IRIS_NAMESPACE=USER
IRIS_USERNAME=_SYSTEM
IRIS_PASSWORD=SYS

# ── Microsoft SQL Server ───────────────────────────────────────────────────────
# Poner en true para habilitar esta integración
MSSQL_ENABLED=false
MSSQL_HOSTNAME=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=my_database
MSSQL_USERNAME=sa
MSSQL_PASSWORD=MyStr0ngP@ssword
# MSSQL_ENCRYPT=true            # Requerido para Azure SQL; false para instancias locales
# MSSQL_TRUST_SERVER_CERT=false  # true solo en entornos dev con certificados autofirmados

# ── Azure DevOps ───────────────────────────────────────────────────────────────
# Poner en true para habilitar esta integración
ADO_ENABLED=false
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/my-organization
AZURE_DEVOPS_PAT=your-personal-access-token
