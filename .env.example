# ── Servidor MCP ──────────────────────────────────────────────────────────────
MCP_SERVER_NAME=FC-MCP-Server
MCP_SERVER_VERSION=1.0.0

# ── InterSystems IRIS ──────────────────────────────────────────────────────────
# Poner en false para deshabilitar esta integración
IRIS_ENABLED=true
IRIS_HOSTNAME=localhost
IRIS_PORT=1972
IRIS_NAMESPACE=USER
IRIS_USERNAME=_SYSTEM
IRIS_PASSWORD=SYS

# ── Microsoft SQL Server ───────────────────────────────────────────────────────
# Poner en true para habilitar esta integración
MSSQL_ENABLED=false
MSSQL_HOSTNAME=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=my_database
MSSQL_USERNAME=sa
MSSQL_PASSWORD=MyStr0ngP@ssword
# MSSQL_ENCRYPT=true            # Requerido para Azure SQL; false para instancias locales
# MSSQL_TRUST_SERVER_CERT=false  # true solo en entornos dev con certificados autofirmados

# ── Autenticación SQL Server ────────────────────────────────────────────────────
# MSSQL_AUTH=sql               # "sql" (usuario/contraseña SQL) | "azure-ad-password" (Entra ID)
#
# Para "azure-ad-password" (equivale a "Active Directory - Password" de DBeaver):
#   - MSSQL_USERNAME debe ser el correo Entra ID (ej: usuario@empresa.cl)
#   - MSSQL_PASSWORD es la contraseña de ese usuario
#   - Se requiere una App registrada en Entra ID (client/app ID) y el tenant ID
# Ejemplo Azure SQL:
# MSSQL_AUTH=azure-ad-password
# MSSQL_HOSTNAME=mi-servidor.database.windows.net
# MSSQL_DATABASE=mi_base_datos
# MSSQL_USERNAME=usuario@empresa.cl
# MSSQL_PASSWORD=tu-contraseña-entra-id
# MSSQL_AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
# MSSQL_AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
# MSSQL_ENCRYPT=true

# ── Azure DevOps ───────────────────────────────────────────────────────────────
# Poner en true para habilitar esta integración
ADO_ENABLED=false
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/my-organization
AZURE_DEVOPS_PAT=your-personal-access-token
